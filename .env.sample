# Server
# Port the server will listen on (required)
SERVER_LISTEN_PORT=

# Logging
# Log level: DEBUG, INFO, WARN, ERROR (default: INFO)
# LOG_LEVEL=INFO

# Database
# Set ENABLE_DATABASE=true and configure DB_* vars to connect to SQL Server.
# The setup wizard can enable this automatically.
ENABLE_DATABASE=false
# DB_HOST=
# DB_DATABASE=
# DB_USER=
# DB_PASSWORD=

# Azure AD / Microsoft Graph
# Tenant ID, client ID, and client secret from your Azure app registration.
# Leave unset to disable Graph features.
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=
# AZURE_TENANT_ID=
# AZURE_REDIRECT_URL=
# AZURE_LOGOUT_REDIRECT_URL=
# AZURE_LOGIN_REDIRECT_URL=

# Hour of day (0-23) to refresh the Azure user cache (default: 5)
# GRAPH_USERCACHE_REFRESH_HOUR=5

# Session
# Secret used for session encryption (required when auth is enabled)
# SESSION_SECRET=

# Application name (required)
APP_NAME=

# CSRF (gorilla/csrf) — uses SESSION_SECRET as the auth key.
# No additional configuration needed; token rotation is automatic.

# Photo download
# Enable downloading user photos from Microsoft Graph (default: false)
# ENABLE_PHOTO_DOWNLOAD=false
