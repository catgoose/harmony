# Server
APP_NAME=
SERVER_LISTEN_PORT=
LOG_LEVEL=INFO
SESSION_SECRET=change-me-in-production

# Database (set DATABASE_URL to enable)
# DATABASE_URL=sqlite:///db/app.db

# OIDC Authentication
# OIDC_ISSUER_URL=https://login.microsoftonline.com/{tenant-id}/v2.0
# OIDC_CLIENT_ID=
# OIDC_CLIENT_SECRET=
# OIDC_REDIRECT_URL=https://localhost:3000/callback
# OIDC_LOGOUT_REDIRECT_URL=https://localhost:3000
# OIDC_LOGIN_REDIRECT_URL=https://localhost:3000

# Azure Graph API
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=

# CSRF — uses SESSION_SECRET as the HMAC key
# CSRF_ROTATE_PER_REQUEST=false
# CSRF_PER_REQUEST_PATHS=

# Photo download
# ENABLE_PHOTO_DOWNLOAD=false

# Graph user cache refresh hour (0-23, default: 5)
# GRAPH_USERCACHE_REFRESH_HOUR=5
