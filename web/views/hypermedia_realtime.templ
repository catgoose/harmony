// --- Per-Service Latency (multi-line chart) ---

templ serviceLatencyChart(svcLatencies []ServiceLatency, maxMs float64) {
	<div id="svc-latency-content">
		<table id="svc-latency-chart" class="charts-css bar show-labels show-data-on-hover data-spacing-4">
			<tbody>
				for _, svc := range svcLatencies {
					<tr>
						<th scope="row" class="text-xs">{ svc.Name }</th>
						<td style={ svcLatencyBarStyle(svc, maxMs) }>
							<span class="tooltip">{ fmtMs(svcLatestLatency(svc)) }</span>
						</td>
					</tr>
				}
			</tbody>
		</table>
	</div>
}

templ oobServiceLatencyChart(svcLatencies []ServiceLatency, maxMs float64) {
	<div id="svc-latency-content" hx-swap-oob="innerHTML">
		<table id="svc-latency-chart" class="charts-css bar show-labels show-data-on-hover data-spacing-4">
			<tbody>
				for _, svc := range svcLatencies {
					<tr>
						<th scope="row" class="text-xs">{ svc.Name }</th>
						<td style={ svcLatencyBarStyle(svc, maxMs) }>
							<span class="tooltip">{ fmtMs(svcLatestLatency(svc)) }</span>
						</td>
					</tr>
				}
			</tbody>
		</table>
	</div>
}

// --- Disk I/O (column chart, 2 series) ---

templ diskIOChart(snap MetricsSnapshot) {
	<div id="disk-io-content">
		<div class="chart-legend mb-2">
			<span class="chart-legend-item"><span class="chart-legend-dot" style="background:#34d399"></span> Read</span>
			<span class="chart-legend-item"><span class="chart-legend-dot" style="background:#fbbf24"></span> Write</span>
		</div>
		<table id="disk-io-chart" class="charts-css column multiple data-spacing-4">
			<tbody>
				for _, d := range diskIOStyles(snap) {
					<tr>
						<td style={ d.ReadStyle }></td>
						<td style={ d.WriteStyle }></td>
					</tr>
				}
			</tbody>
		</table>
	</div>
}

